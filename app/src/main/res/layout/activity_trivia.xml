<?xml version="1.0" encoding="utf-8"?>
<!-- Añadimos el ID 'llPantallaTrivia' para manipular el fondo desde Kotlin -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/llPantallaTrivia"
    android:layout_width="wrap_content"
    android:minWidth="480dp"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#121212"
    android:gravity="center_horizontal">

    <TextView
        android:id="@+id/tvBienvenida"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#BB86FC"
        android:textSize="18sp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tvPregunta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <RadioGroup
        android:id="@+id/rgOpciones"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp">

        <RadioButton android:id="@+id/rbOpcion1" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#03DAC5" />
        <RadioButton android:id="@+id/rbOpcion2" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#03DAC5" />
        <RadioButton android:id="@+id/rbOpcion3" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#03DAC5" />
        <RadioButton android:id="@+id/rbOpcion4" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#03DAC5" />
    </RadioGroup>

    <Button
        android:id="@+id/btnResponder"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/validar_opcion" />

    <Button
        android:id="@+id/btnTema"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/btnTema"
        android:layout_marginBottom="16dp"/>

</LinearLayout>

